[Unit]
Description=Memento repository audit

[Service]
Type=oneshot
User=memento
Group=memento
EnvironmentFile=-/etc/memento/memento.env
ExecStart=/opt/memento/.venv/bin/memento-serve --config /etc/memento/config.json audit
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/memento
StateDirectory=memento
