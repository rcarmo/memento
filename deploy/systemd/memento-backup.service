[Unit]
Description=Memento local backup

[Service]
Type=oneshot
User=memento
Group=memento
EnvironmentFile=-/etc/memento/memento.env
ExecStart=/opt/memento/.venv/bin/memento-serve --config /etc/memento/config.json backup --output /srv/memento-backups/latest
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/memento /srv/memento-backups
StateDirectory=memento
