{
  "schema_version": 2,
  "repository": {
    "root_path": "/var/lib/memento",
    "bundle_root": "/"
  },
  "authorization": {
    "principals": {
      "smith": {
        "roles": ["reader", "proposer", "curator"],
        "token_env": "MEMENTO_TOKEN_SMITH",
        "read_prefixes": ["/instances/", "/projects/"],
        "write_prefixes": ["/instances/", "/projects/"]
      },
      "flint": {
        "roles": ["reader", "proposer"],
        "token_env": "MEMENTO_TOKEN_FLINT",
        "read_prefixes": ["/instances/", "/projects/"],
        "write_prefixes": ["/projects/"]
      }
    }
  },
  "limits": {
    "max_concept_bytes": 262144,
    "max_search_results": 100
  },
  "mcp": {
    "tool_surface": "compact",
    "compact_answer_enabled": true,
    "execute": {
      "max_operations": 12,
      "max_intermediates": 12,
      "max_records": 50,
      "max_output_bytes": 65536,
      "max_time_seconds": 3.0
    }
  },
  "intelligent_tiers": {
    "deep_answers": {
      "enabled": false,
      "model_policy_revision": "disabled",
      "prompt_version": "v1",
      "tool_version": "v1",
      "trace_max_entries": 50,
      "trace_max_age_days": 30,
      "limits": {
        "max_steps": 8,
        "max_time_seconds": 3.0,
        "max_concepts": 6,
        "max_chars": 12000,
        "max_answer_chars": 2000
      }
    },
    "exact_answer_cache": {
      "enabled": false,
      "ttl_seconds": 86400,
      "max_entries": 200
    },
    "hot_working_memory": {
      "enabled": false,
      "ttl_seconds": 3600,
      "max_changed_concepts": 10,
      "max_answers": 10,
      "max_excerpt_chars": 4000
    },
    "model_proposals": {
      "enabled": false,
      "model_policy_revision": "disabled",
      "prompt_version": "v1",
      "tool_version": "v1",
      "limits": {
        "max_search_results": 5,
        "max_consulted_concepts": 6,
        "max_context_chars": 12000,
        "max_output_chars": 8000,
        "max_diff_chars": 2000000,
        "max_changes": 20,
        "max_body_chars": 32000,
        "max_rationale_chars": 4000,
        "max_secret_entropy_chars": 32
      }
    },
    "dream": {
      "mode": "disabled",
      "model_policy_revision": "disabled",
      "prompt_version": "v1",
      "tool_version": "v1",
      "interval_seconds": 21600,
      "quiet_period_seconds": 300,
      "scanner": {
        "oversized_body_chars": 6000,
        "oversized_top_level_sections": 6,
        "max_oversized_candidates": 3,
        "duplicate_similarity_threshold": 0.86
      },
      "budgets": {
        "max_signals_per_run": 25,
        "max_model_proposals_per_run": 5,
        "max_runtime_seconds": 30.0,
        "daily_proposal_limit": 20
      }
    },
    "semantic_search": {
      "enabled": false,
      "ffi_library_path": null,
      "sqlite_extension_path": null,
      "model_path": null,
      "model_id": "gte-small-fp32",
      "dimensions": 384,
      "max_input_chars": 4096,
      "max_batch_size": 16,
      "max_candidates": 200,
      "default_search_mode": "lexical"
    },
    "needle_router": {
      "enabled": false,
      "ffi_library_path": "/usr/local/lib/memento/libmemento_needle_ffi.so",
      "model_path": "/usr/local/share/memento/models/memento-router.ndl",
      "tokenizer_path": "/usr/local/share/memento/models/needle.model"
    },
    "model_provider_slots": {
      "hot_query": {
        "primary": {
          "base_url": "http://127.0.0.1:11434",
          "api_format": "openai",
          "api_key_env": null,
          "model": "local/llama",
          "headers": {}
        },
        "fallbacks": [],
        "timeout_seconds": 1.0,
        "max_output_chars": 2000,
        "retry_budget": 0,
        "concurrency_limit": 2,
        "allowed_data_classifications": ["internal"],
        "allow_cross_trust_boundary": false,
        "fallback_enabled": true,
        "fallback_on_rate_limit": false,
        "overload_status_codes": [529]
      },
      "deep_query": {
        "primary": {
          "base_url": "http://127.0.0.1:11434",
          "api_format": "openai",
          "api_key_env": null,
          "model": "local/llama",
          "headers": {}
        },
        "fallbacks": [
          {
            "base_url": "https://api.openai.example",
            "api_format": "openai",
            "api_key_env": "MEMENTO_OPENAI_API_KEY",
            "model": "gpt-4o-mini",
            "headers": {}
          }
        ],
        "timeout_seconds": 3.0,
        "max_output_chars": 2000,
        "retry_budget": 1,
        "concurrency_limit": 2,
        "allowed_data_classifications": ["internal"],
        "allow_cross_trust_boundary": true,
        "fallback_enabled": true,
        "fallback_on_rate_limit": false,
        "overload_status_codes": [529]
      },
      "proposal": {
        "primary": null,
        "fallbacks": [],
        "timeout_seconds": 5.0,
        "max_output_chars": 8000,
        "retry_budget": 0,
        "concurrency_limit": 1,
        "allowed_data_classifications": ["restricted"],
        "allow_cross_trust_boundary": false,
        "fallback_enabled": false,
        "fallback_on_rate_limit": false,
        "overload_status_codes": [529]
      },
      "dream": {
        "primary": null,
        "fallbacks": [],
        "timeout_seconds": 5.0,
        "max_output_chars": 8000,
        "retry_budget": 0,
        "concurrency_limit": 1,
        "allowed_data_classifications": ["restricted"],
        "allow_cross_trust_boundary": false,
        "fallback_enabled": false,
        "fallback_on_rate_limit": false,
        "overload_status_codes": [529]
      }
    }
  }
}
