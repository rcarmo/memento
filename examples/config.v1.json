{
  "schema_version": 1,
  "repository": {
    "root_path": "/var/lib/memento",
    "bundle_root": "/"
  },
  "authorization": {
    "principals": {
      "smith": {
        "roles": ["reader", "proposer", "curator"],
        "read_prefixes": ["/instances/", "/projects/"],
        "write_prefixes": ["/instances/", "/projects/"]
      },
      "flint": {
        "roles": ["reader", "proposer"],
        "read_prefixes": ["/instances/", "/projects/"],
        "write_prefixes": ["/projects/"]
      }
    }
  },
  "limits": {
    "max_concept_bytes": 262144,
    "max_search_results": 100
  },
  "intelligent_tiers": {
    "deep_answers": {
      "enabled": false,
      "model_policy_revision": "disabled",
      "prompt_version": "v1",
      "tool_version": "v1",
      "trace_max_entries": 50,
      "trace_max_age_days": 30,
      "limits": {
        "max_steps": 8,
        "max_time_seconds": 3.0,
        "max_concepts": 6,
        "max_chars": 12000,
        "max_answer_chars": 2000
      }
    },
    "exact_answer_cache": {
      "enabled": false,
      "ttl_seconds": 86400,
      "max_entries": 200
    },
    "hot_working_memory": {
      "enabled": false,
      "ttl_seconds": 3600,
      "max_changed_concepts": 10,
      "max_answers": 10,
      "max_excerpt_chars": 4000
    },
    "model_proposals": {
      "enabled": false,
      "model_policy_revision": "disabled",
      "prompt_version": "v1",
      "tool_version": "v1",
      "limits": {
        "max_search_results": 5,
        "max_consulted_concepts": 6,
        "max_context_chars": 12000,
        "max_output_chars": 8000,
        "max_diff_chars": 2000000,
        "max_changes": 20,
        "max_body_chars": 32000,
        "max_rationale_chars": 4000,
        "max_secret_entropy_chars": 32
      }
    }
  }
}
