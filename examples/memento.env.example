# Copy to .env for Docker Compose or /etc/memento/memento.env for systemd.
# These bearer-token variables are required by examples/config.v1.json.
MEMENTO_TOKEN_SMITH=replace-with-reader-proposer-curator-token
MEMENTO_TOKEN_FLINT=replace-with-reader-proposer-token

# Optional model-provider example variable referenced by examples/config.v1.json.
MEMENTO_OPENAI_API_KEY=
